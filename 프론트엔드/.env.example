# 로컬 개발 — 비워두면 자동 선택
#   · localhost:5173 (Vite) → /api 프록시 → 8787
#   · localhost:8081 (Granite shell) → 127.0.0.1:8787 직접 연결
# 강제로 직접 연결: VITE_API_URL=http://127.0.0.1:8787
# 강제로 프록시만: VITE_API_URL=

# 앱인토스 인앱광고 (live)
# 1. 배너형 글광고
VITE_TOSS_TEXT_BANNER_AD_GROUP_ID=ait.v2.live.2fe2c692b337425b
# 2. 배너형 이미지 강조 광고
VITE_TOSS_IMAGE_BANNER_AD_GROUP_ID=ait.v2.live.eb8a9681efbe49b5
# 3. 리워드 보상 (광고 끝까지 시청)
VITE_TOSS_REWARDED_AD_GROUP_ID=ait.v2.live.d1a37fcea48c4f83
# 4. 전면 광고 (화면 전환)
VITE_TOSS_INTERSTITIAL_AD_GROUP_ID=ait.v2.live.64d34a1ab30647cc

# 개발·샌드박스에서 테스트 광고 ID 강제 (ait-ad-test-*)
# VITE_TOSS_USE_TEST_ADS=true

# 랭킹 TOP3 토스 프로모션 (운영 배포 시 설정)
# VITE_TOSS_RANKING_TOP3_PROMOTION_CODE=
# 하위 호환: VITE_TOSS_COFFEE_VALUE_PROMOTION_CODE 도 사용 가능

# DEV — 프로모션 코드 없을 때 랭킹 보상 지급 플로우 시뮬레이션 (로컬 전용)
# 코드가 있어도 강제 시뮬레이션: VITE_MOCK_RANKING_TOP3_PROMOTION=1
