PORT=8787

# 토스 로그인 mTLS (앱인토스 콘솔 > 개발에서 발급)
# cert/public.crt, cert/private.key 를 백엔드/cert/ 에 넣고 경로 지정
TOSS_CLIENT_CERT_PATH=cert/public.crt
TOSS_CLIENT_KEY_PATH=cert/private.key

# 토스 로그인 사용자 정보 복호화 (콘솔 > 이메일로 복호화 키 받기)
# DECRYPTION_KEY_BASE64=
# AAD_STRING=

# 연결 끊기 콜백 Basic Auth (선택)
# TOSS_UNLINK_CALLBACK_AUTH=clientId:clientSecret

# DATABASE_URL=
# SUPABASE_URL=
# SUPABASE_SECRET_KEY=
